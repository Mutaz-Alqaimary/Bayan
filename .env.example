# Bayan — required environment variables.
# Copy to `.env.local` for local development and set the same keys in the Vercel
# project settings (Production, Preview, Development). Never commit real secrets.
# See docs/Deployment.md for details.

# Supabase project URL (public — inlined into the browser bundle).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (public — inlined into the browser bundle).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key (SERVER-ONLY — bypasses RLS, never expose to clients).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site origin, no trailing slash. Used for metadataBase, canonical /
# hreflang URLs, robots.txt, sitemap.xml, and auth redirect links.
NEXT_PUBLIC_SITE_URL=https://bayan-reading.vercel.app
