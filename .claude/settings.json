{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint *)",
      "Bash(npm run test *)",
      "Bash(npm install *)",
      "Bash(npm ci)",
      "Bash(npx tsc *)",
      "Bash(npx next *)",
      "Bash(npx supabase gen types *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Read(./docs/**)",
      "Read(./.claude/**)"
    ],
    "ask": [
      "Bash(npx supabase db push *)",
      "Bash(npx supabase db reset *)",
      "Bash(npx supabase migration *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./supabase/migrations/**)",
      "Edit(./**/*.sql)"
    ]
  },
  "env": {}
}
